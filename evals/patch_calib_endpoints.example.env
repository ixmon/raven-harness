# Copy to patch_calib_endpoints.env and customize.
# Format: one endpoint per block; the script reads ENDPOINT_<slug>_* variables.
#
# slug is used in reports (letters, numbers, dash only).

ENDPOINT_local_LABEL="local qwen"
ENDPOINT_local_URL="http://127.0.0.1:8080/v1"
ENDPOINT_local_MODEL="qwen3-coder-next"
ENDPOINT_local_KEY=""

# Requires OPENROUTER_API_KEY in the environment (or set ENDPOINT_openrouter_KEY).
# ENDPOINT_openrouter_LABEL="openrouter kimi"
# ENDPOINT_openrouter_URL="https://openrouter.ai/api/v1"
# ENDPOINT_openrouter_MODEL="moonshotai/kimi-k2.6"
# ENDPOINT_openrouter_KEY=""
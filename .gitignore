# Rust / Cargo
# Build output
/target/
debug/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC debugging info
*.pdb

# IDE and editor files
.idea/
.vscode/
*.swp
*~
*.swo
# Vim swap variants (e.g. .swl / .swm / .swn when .swp is blocked)
*.sw[a-z]
.sw[a-z]

# OS generated files (recursive to catch them in subdirectories)
**/.DS_Store
**/Thumbs.db
**/ehthumbs.db

# Environment / secrets (if you ever add any)
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
*.log
*.bak

# Any local test or scratch files
*.rs.fmt
*.orig

# Session / runtime data (this repo uses ~/.raven-hotel/ for user sessions)
# but ignore anything that might accidentally end up in the tree
sessions/
*.db
*.sqlite

# If you ever build release binaries locally and don't want them tracked
# (uncomment if desired)
# *.exe
# *.out

# Internal review / scratch notes (uncomment if you want to keep these out of the repo)
# instructions.md

# Note: Cargo.lock is intentionally committed because this is a binary application,
# not a library. This ensures reproducible builds for users.
